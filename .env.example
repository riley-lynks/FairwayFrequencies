# =============================================================================
# .env.example — API Key Template for Fairway Frequencies
# =============================================================================
# INSTRUCTIONS:
#   1. Copy this file and rename the copy to ".env" (remove the ".example" part)
#   2. Fill in your actual API keys next to each variable
#   3. NEVER share your .env file or commit it to git — it contains secrets!
#
# HOW TO GET EACH KEY (links are current as of March 2026):
#   Anthropic: https://console.anthropic.com/  → API Keys
#   BFL:       https://api.bfl.ml/              → Sign up → API Keys
#   Mubert:    https://mubert.com/render/pricing → API Plans
#   Freesound: https://freesound.org/apiv2/apply/ → Apply for API key
#   YouTube:   https://console.cloud.google.com/ → APIs → YouTube Data API v3
#
# NOTE — Kling video clips are generated MANUALLY via the web app:
#   app.klingai.com → AI Videos → Image to Video
#   No API key needed. Run --prompts-only to get all animation prompts.
# =============================================================================

# --- Claude AI (prompt decomposition + metadata generation) ---
# Required for the pipeline to work at all.
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# --- Black Forest Labs (Flux 2 image generation — automated path only) ---
# Only required if IMAGE_SOURCE = "flux" in config.py
# If you're using Midjourney manual path, you can leave this blank.
BFL_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# --- Mubert (LoFi music generation) ---
# Optional if you have pre-made tracks in assets/music/
MUBERT_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# --- Freesound (ambient golf course sounds) ---
# Optional if INCLUDE_AMBIENCE = False in config.py
FREESOUND_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# --- YouTube Data API (OPTIONAL — only for auto-upload feature) ---
# Only needed if you use the --upload flag
# Leave blank to skip YouTube integration entirely.
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=
